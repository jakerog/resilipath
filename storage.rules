rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Evidence collection: Tenant isolation (M2)
    // Files must be prefixed with their tenantId.
    match /evidence/{tenantId}/{allPaths=**} {
      allow read, write: if request.auth != null &&
                          request.auth.token.tenantId == tenantId;
    }
  }
}
